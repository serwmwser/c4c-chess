node_modules/
.pnp
.pnp.js

# --- Файлы сборки и вывода (генерируются автоматически) ---
build/
dist/
.next/
out/
*.tsbuildinfo

# --- Переменные окружения (ВАЖНО: скрывает все .env файлы во всех папках) ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# --- Логи и отчеты об ошибках ---
npm-debug.log*
